---
// Quvii global header — Apple/DJI pattern.
//   • Transparent over hero (white text/logo)
//   • Solid white with hairline border on scroll OR non-home pages
//   • Mobile (<lg) hamburger → full-screen overlay menu
//
// Detects home page via Astro.url.pathname === "/" so secondary pages
// always render solid-white (no transparent state) — they don't have a
// dark hero behind the header.

const isHome = Astro.url.pathname === "/";

interface NavItem { href: string; label: string }
const nav: NavItem[] = [
  { href: "/reviews/", label: "Reviews" },
  { href: "/learn/",   label: "Guides"  },
  { href: "/blog/",    label: "Insights" },
  { href: "/news/",    label: "News"    },
  { href: "/about/",   label: "About"   },
];
---

<header
  data-home={isHome ? "1" : "0"}
  class={`fixed top-0 inset-x-0 z-40 transition-colors duration-200 ${isHome ? "qv-header" : "bg-white/95 border-b border-body-line backdrop-blur"}`}
>
  <div class="container-wide flex items-center justify-between h-14 lg:h-16">
    <a href="/" class="flex items-center gap-2 no-underline qv-brand">
      <span class="qv-logo-mark inline-flex h-7 w-7 items-center justify-center rounded-md text-sm font-bold transition-colors">Q</span>
      <span class="qv-logo-text font-display text-lg font-semibold tracking-tight transition-colors">Quvii</span>
    </a>

    <nav class="hidden lg:flex items-center gap-8 text-sm font-medium">
      {nav.map((item) => (
        <a href={item.href} class="qv-link transition-colors no-underline">{item.label}</a>
      ))}
    </nav>

    <div class="hidden lg:flex items-center">
      <a href="/blog/" class="qv-cta inline-flex items-center gap-1 text-sm font-medium transition-colors no-underline">
        Latest <span aria-hidden="true">›</span>
      </a>
    </div>

    <button
      id="qv-mobile-toggle"
      type="button"
      aria-label="Open menu"
      aria-controls="qv-mobile-menu"
      aria-expanded="false"
      class="qv-burger lg:hidden inline-flex h-9 w-9 items-center justify-center rounded-md transition-colors"
    >
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="3" y1="7" x2="21" y2="7" />
        <line x1="3" y1="17" x2="21" y2="17" />
      </svg>
    </button>
  </div>
</header>

<!-- Spacer so non-home pages don't have content slide under the fixed header.
     Home page hero handles its own top padding (pt-32+) so no spacer there. -->
{!isHome && <div class="h-14 lg:h-16" aria-hidden="true"></div>}

<!-- Full-screen mobile menu overlay -->
<div
  id="qv-mobile-menu"
  class="fixed inset-0 z-50 hidden bg-ink text-white"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
>
  <div class="container-wide flex items-center justify-between h-14 lg:h-16">
    <a href="/" class="flex items-center gap-2 no-underline text-white">
      <span class="inline-flex h-7 w-7 items-center justify-center rounded-md bg-primary-500 text-white text-sm font-bold">Q</span>
      <span class="font-display text-lg font-semibold tracking-tight">Quvii</span>
    </a>
    <button
      id="qv-mobile-close"
      type="button"
      aria-label="Close menu"
      class="inline-flex h-9 w-9 items-center justify-center rounded-md text-white hover:bg-white/10"
    >
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="6" y1="18" x2="18" y2="6" />
      </svg>
    </button>
  </div>

  <nav class="container-wide mt-8 flex flex-col gap-1">
    {nav.map((item) => (
      <a
        href={item.href}
        class="block py-4 text-3xl font-semibold tracking-display text-white no-underline border-b border-white/10 hover:text-primary-300 transition-colors"
      >
        {item.label}
      </a>
    ))}
  </nav>

  <div class="container-wide mt-10 flex flex-col gap-3 text-sm text-white/60">
    <a href="/editorial-policy/" class="no-underline hover:text-white">Standards</a>
    <a href="/affiliate-disclosure/" class="no-underline hover:text-white">Disclosures</a>
    <a href="/privacy/" class="no-underline hover:text-white">Privacy</a>
  </div>
</div>

<style>
  /* Home: transparent header, white text. After scroll → white bg + dark text. */
  header.qv-header {
    background-color: transparent;
    border-bottom: 1px solid transparent;
  }
  header.qv-header .qv-link,
  header.qv-header .qv-cta,
  header.qv-header .qv-logo-text,
  header.qv-header .qv-burger {
    color: rgba(255,255,255,0.92);
  }
  header.qv-header .qv-link:hover,
  header.qv-header .qv-cta:hover {
    color: #ffffff;
  }
  header.qv-header .qv-logo-mark {
    background-color: #ffffff;
    color: theme('colors.ink.DEFAULT');
  }
  header.qv-header.is-scrolled {
    background-color: rgba(255,255,255,0.95);
    border-bottom-color: theme('colors.body.line');
    backdrop-filter: blur(10px);
  }
  header.qv-header.is-scrolled .qv-link,
  header.qv-header.is-scrolled .qv-logo-text,
  header.qv-header.is-scrolled .qv-burger {
    color: theme('colors.ink.DEFAULT');
  }
  header.qv-header.is-scrolled .qv-cta {
    color: theme('colors.primary.600');
  }
  header.qv-header.is-scrolled .qv-logo-mark {
    background-color: theme('colors.primary.500');
    color: #ffffff;
  }

  /* Non-home (always solid white): brand mark is cobalt, links are ink. */
  header:not(.qv-header) .qv-link,
  header:not(.qv-header) .qv-logo-text,
  header:not(.qv-header) .qv-burger {
    color: theme('colors.ink.DEFAULT');
  }
  header:not(.qv-header) .qv-link:hover {
    color: theme('colors.primary.700');
  }
  header:not(.qv-header) .qv-cta {
    color: theme('colors.primary.600');
  }
  header:not(.qv-header) .qv-logo-mark {
    background-color: theme('colors.primary.500');
    color: #ffffff;
  }
</style>

<script is:inline>
  (function () {
    var hdr = document.querySelector('header[data-home="1"]');
    if (hdr) {
      var onScroll = function () {
        if (window.scrollY > 8) hdr.classList.add('is-scrolled');
        else hdr.classList.remove('is-scrolled');
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    var menu = document.getElementById('qv-mobile-menu');
    var openBtn = document.getElementById('qv-mobile-toggle');
    var closeBtn = document.getElementById('qv-mobile-close');
    function open() {
      menu.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      openBtn.setAttribute('aria-expanded', 'true');
    }
    function close() {
      menu.classList.add('hidden');
      document.body.style.overflow = '';
      openBtn.setAttribute('aria-expanded', 'false');
    }
    if (openBtn) openBtn.addEventListener('click', open);
    if (closeBtn) closeBtn.addEventListener('click', close);
    // Close on Escape + when a nav link is clicked
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && menu && !menu.classList.contains('hidden')) close();
    });
    if (menu) {
      menu.addEventListener('click', function (e) {
        var t = e.target;
        if (t && t.tagName === 'A') close();
      });
    }
  })();
</script>

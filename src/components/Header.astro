---
// Quvii header — sticky white nav with cobalt accent.
// Phase 0: all paths are Astro (root-served). Phase 1+ /products /cart
// /checkout become Shopify via CF Worker reverse proxy — this header
// links to them identically; the user can't tell the cutover happened.
---

<header class="sticky top-0 z-30 border-b border-body-line bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 h-14">
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-primary-500 text-white text-sm font-bold shadow-glow-primary">
        Q
      </span>
      <span class="text-ink font-display text-lg font-semibold tracking-tight">Quvii</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-body-muted">
      <a href="/products/" class="hover:text-ink no-underline">Cameras</a>
      <a href="/reviews/" class="hover:text-ink no-underline">Reviews</a>
      <a href="/blog/" class="hover:text-ink no-underline">Blog</a>
      <a href="/learn/" class="hover:text-ink no-underline">Learn</a>
      <a href="/support/" class="hover:text-ink no-underline">Support</a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/#notify"
        class="hidden sm:inline-flex items-center rounded-md bg-primary-500 px-3 py-1.5 text-sm font-medium text-white no-underline hover:bg-primary-600"
      >
        Get notified →
      </a>
    </div>
  </div>
</header>

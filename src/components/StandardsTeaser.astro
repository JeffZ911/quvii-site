---
// Compact editorial-standards teaser — links to /editorial-policy/.
// Lives between content streams to reinforce credibility without
// adopting "publication" framing. Tone: confident, brand-tech-company.
---

<section class="section-tight bg-ink text-white">
  <div class="container-page grid items-center gap-10 lg:grid-cols-[1.1fr_1fr]">
    <div>
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary-300">Standards</p>
      <h2 class="mt-4 font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-white leading-[1.1]">
        Every claim, traceable.
      </h2>
      <p class="mt-6 text-base text-white/70 leading-relaxed max-w-xl">
        Four source classes — manufacturer documentation, independent technical
        reviewers, verifiable community consensus, direct hands-on measurement.
        Six QA dimensions per draft. A hard factual-accuracy gate that
        auto-rejects unverifiable claims. Human review on every piece.
      </p>
      <a
        href="/editorial-policy/"
        class="mt-8 inline-flex items-center gap-1 text-sm font-medium text-white hover:text-primary-300 no-underline transition-colors"
      >
        Read the full standards <span aria-hidden="true">›</span>
      </a>
    </div>

    <div class="grid grid-cols-2 gap-6 text-white/70">
      <div class="border-t border-white/20 pt-4">
        <p class="font-display text-3xl sm:text-4xl font-semibold tracking-display text-white">4</p>
        <p class="mt-1 text-xs uppercase tracking-[0.18em]">Source classes</p>
      </div>
      <div class="border-t border-white/20 pt-4">
        <p class="font-display text-3xl sm:text-4xl font-semibold tracking-display text-white">6</p>
        <p class="mt-1 text-xs uppercase tracking-[0.18em]">QA dimensions</p>
      </div>
      <div class="border-t border-white/20 pt-4">
        <p class="font-display text-3xl sm:text-4xl font-semibold tracking-display text-white">6.0</p>
        <p class="mt-1 text-xs uppercase tracking-[0.18em]">Publish floor</p>
      </div>
      <div class="border-t border-white/20 pt-4">
        <p class="font-display text-3xl sm:text-4xl font-semibold tracking-display text-white">0</p>
        <p class="mt-1 text-xs uppercase tracking-[0.18em]">Paid placements</p>
      </div>
    </div>
  </div>
</section>

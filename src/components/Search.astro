---
// Header search powered by Pagefind. The index is generated by
// `pagefind --site dist` during the build script, then served at
// /_pagefind/*. We load the Pagefind UI lazily on first focus so it
// doesn't add any cost to the initial page load.
---

<div class="relative" data-search-root>
  <button
    type="button"
    aria-label="Search articles"
    data-search-trigger
    class="hidden md:inline-flex items-center gap-2 rounded-md border border-white/10 bg-bg-soft/50 px-3 py-1.5 text-xs text-gray-400 hover:border-primary-400/40 hover:text-gray-200"
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="11" cy="11" r="7" />
      <path d="m21 21-4.3-4.3" />
    </svg>
    <span>Search</span>
    <span class="ml-1 hidden lg:inline rounded border border-white/10 px-1 text-[10px] text-gray-500">/</span>
  </button>

  <!-- Modal overlay -->
  <div
    data-search-modal
    class="fixed inset-0 z-50 hidden bg-black/70 backdrop-blur-sm"
    aria-hidden="true"
  >
    <div class="mx-auto mt-24 max-w-2xl rounded-xl border border-white/10 bg-bg-soft p-4 shadow-2xl">
      <div class="flex items-center justify-between mb-3">
        <h3 class="m-0 text-sm font-semibold text-gray-200">Search the Quvii Blog</h3>
        <button
          type="button"
          data-search-close
          aria-label="Close search"
          class="rounded p-1 text-gray-400 hover:bg-white/5 hover:text-white"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      </div>
      <div id="pagefind-search" class="pagefind-ui-dark" />
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const root = document.querySelector("[data-search-root]");
    if (!root) return;
    const trigger = root.querySelector("[data-search-trigger]");
    const modal = root.querySelector("[data-search-modal]");
    const closeBtn = root.querySelector("[data-search-close]");
    const container = root.querySelector("#pagefind-search");

    let pfLoaded = false;
    async function loadPagefind() {
      if (pfLoaded) return;
      pfLoaded = true;
      // Inject CSS
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = "/_pagefind/pagefind-ui.css";
      document.head.appendChild(link);
      // Inject JS
      const script = document.createElement("script");
      script.src = "/_pagefind/pagefind-ui.js";
      script.onload = () => {
        new window.PagefindUI({
          element: "#pagefind-search",
          showSubResults: true,
          showImages: false,
          resetStyles: false,
        });
        setTimeout(() => {
          const input = container.querySelector("input");
          if (input) input.focus();
        }, 100);
      };
      document.body.appendChild(script);
    }

    function openSearch() {
      modal.classList.remove("hidden");
      modal.setAttribute("aria-hidden", "false");
      loadPagefind().then(() => {
        const input = container.querySelector("input");
        if (input) input.focus();
      });
    }
    function closeSearch() {
      modal.classList.add("hidden");
      modal.setAttribute("aria-hidden", "true");
    }

    trigger.addEventListener("click", openSearch);
    closeBtn.addEventListener("click", closeSearch);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeSearch();
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeSearch();
      if (e.key === "/" && !e.target.matches("input, textarea")) {
        e.preventDefault();
        openSearch();
      }
    });
  })();
</script>

<style is:global>
  /* Tone Pagefind down to match the dark theme */
  .pagefind-ui-dark .pagefind-ui__form input {
    background: rgb(15 17 26 / 1);
    color: rgb(229 231 235 / 1);
    border: 1px solid rgb(255 255 255 / 0.1);
  }
  .pagefind-ui-dark .pagefind-ui__result {
    background: rgb(20 23 35 / 1);
    color: rgb(229 231 235 / 1);
    border-bottom: 1px solid rgb(255 255 255 / 0.05);
  }
  .pagefind-ui-dark .pagefind-ui__result-title a {
    color: rgb(229 231 235 / 1);
  }
  .pagefind-ui-dark .pagefind-ui__result-excerpt {
    color: rgb(156 163 175 / 1);
  }
  .pagefind-ui-dark mark {
    background: rgb(99 102 241 / 0.3);
    color: rgb(255 255 255 / 1);
  }
</style>

---
// Compact 4-up news ribbon — high-density industry-signal block.
// Smaller-than-ArticleTile cards, no images required (text-led), date-stamped.
// Pattern reference: The Verge / Bloomberg homepage news strips.

interface NewsItem {
  href: string;
  title: string;
  publishedAt?: string;
  image?: string;
}

interface Props {
  eyebrow?: string;
  headline?: string;
  ctaHref?: string;
  ctaLabel?: string;
  items: NewsItem[];
}

const {
  eyebrow = "Signals",
  headline = "From the wire.",
  ctaHref = "/news/",
  ctaLabel = "All news",
  items,
} = Astro.props;

const fmt = (d?: string) => d
  ? new Date(d).toLocaleDateString("en-US", { month: "short", day: "numeric" })
  : null;
---

<section class="section-tight bg-surface border-t border-body-line">
  <div class="container-page">
    <div class="flex flex-wrap items-end justify-between gap-4 mb-10 lg:mb-14">
      <div>
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary-600">{eyebrow}</p>
        <h2 class="mt-3 font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-ink leading-[1.1]">
          {headline}
        </h2>
      </div>
      <a href={ctaHref} class="inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 no-underline">
        {ctaLabel} <span aria-hidden="true">›</span>
      </a>
    </div>

    {items.length === 0 ? (
      <p class="text-body-muted">No signals published yet.</p>
    ) : (
      <div class="grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-4">
        {items.map((n) => (
          <a href={n.href} class="group block border-t border-body-line pt-5">
            {n.publishedAt && (
              <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-body-faint">{fmt(n.publishedAt)}</p>
            )}
            <h3 class="mt-3 font-display text-base sm:text-lg font-semibold tracking-tight text-ink leading-[1.25] group-hover:text-primary-700 transition-colors">
              {n.title}
            </h3>
          </a>
        ))}
      </div>
    )}
  </div>
</section>

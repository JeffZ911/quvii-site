---
// ArticleTile — Apple News / DJI Stories-style content tile.
// Large image, headline, optional dek, fine-print meta. NO type badge.
// Used in mixed content streams on homepage and hub pages.

interface Props {
  href: string;
  title: string;
  dek?: string;
  image?: string;
  publishedAt?: string;
  wordCount?: number;
  aspect?: "4/3" | "4/5" | "16/9" | "1/1";
  size?: "default" | "lg";
}

const {
  href, title, dek, image, publishedAt, wordCount,
  aspect = "4/3", size = "default",
} = Astro.props;

const aspectClass = {
  "4/3":  "aspect-[4/3]",
  "4/5":  "aspect-[4/5]",
  "16/9": "aspect-video",
  "1/1":  "aspect-square",
}[aspect];

const titleClass = size === "lg"
  ? "text-xl sm:text-2xl"
  : "text-lg sm:text-xl";

const readMinutes = wordCount ? Math.max(1, Math.round(wordCount / 220)) : null;
const dateStr = publishedAt
  ? new Date(publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : null;
---

<a href={href} class="group block">
  {/* Double-Bezel: outer shell + inner core (DESIGN.md §5) */}
  <div class="bezel transition-transform duration-500 ease-settle group-hover:-translate-y-1">
    <div class={`bezel-core relative ${aspectClass}`}>
      {image ? (
        <img
          src={image}
          alt=""
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-700 ease-settle group-hover:scale-[1.04]"
        />
      ) : (
        <div class="grid h-full w-full place-items-center bg-surface-alt">
          <img src="/brand/q-red.png" alt="" aria-hidden="true" class="h-12 w-auto opacity-[0.10]" />
        </div>
      )}
    </div>
  </div>

  <h3 class={`mt-5 font-display ${titleClass} font-semibold tracking-tight text-ink leading-[1.2] group-hover:text-primary-700 transition-colors duration-300 ease-settle`}>
    {title}
  </h3>
  {dek && (
    <p class="mt-2 text-sm text-body-muted leading-relaxed line-clamp-3">{dek}</p>
  )}
  <div class="mt-3 flex items-center gap-2 text-xs text-body-faint">
    {dateStr && <span>{dateStr}</span>}
    {dateStr && readMinutes && <span aria-hidden="true">·</span>}
    {readMinutes && <span>{readMinutes} min read</span>}
  </div>
</a>

---
// Quvii footer — 5-column nav + bottom legal/disclosure bar.
//
// Phase 0: all paths are Astro. Phase 1+ /products /cart become Shopify
// but the links don't change (CF Worker handles routing).
---

<footer class="mt-24 border-t border-body-line bg-ink text-white">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="grid gap-10 md:grid-cols-6">
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 no-underline text-white">

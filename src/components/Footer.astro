        <ul class="mt-3 space-y-2 list-none p-0">
          <li><a href="/about/" class="text-sm text-white/60 hover:text-white no-underline">About</a></li>
          <li><a href="/warranty/" class="text-sm text-white/60 hover:text-white no-underline">Warranty</a></li>

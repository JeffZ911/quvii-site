          <li><a href="/blog/buying-guides/" class="text-sm text-white/60 hover:text-white no-underline">Buying guides</a></li>
          <li><a href="/blog/comparisons/" class="text-sm text-white/60 hover:text-white no-underline">Comparisons</a></li>
          <li><a href="/learn/" class="text-sm text-white/60 hover:text-white no-underline">Knowledge base</a></li>
          <li><a href="/reviews/" class="text-sm text-white/60 hover:text-white no-underline">Reviews</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mt-0">Support</h3>
        <ul class="mt-3 space-y-2 list-none p-0">
          <li><a href="/support/" class="text-sm text-white/60 hover:text-white no-underline">Help center</a></li>
          <li><a href="/support/setup/" class="text-sm text-white/60 hover:text-white no-underline">Setup guides</a></li>
          <li><a href="/support/troubleshooting/" class="text-sm text-white/60 hover:text-white no-underline">Troubleshooting</a></li>
          <li><a href="/support/firmware/" class="text-sm text-white/60 hover:text-white no-underline">Firmware</a></li>
          <li><a href="/support/contact/" class="text-sm text-white/60 hover:text-white no-underline">Contact</a></li>
        </ul>
      </div>

      <div>

---
// Quvii global footer — brand-tech outpost voice, not publication.
// 5-column nav + bottom legal/disclosure bar.
---

<footer class="mt-0 bg-ink text-white">
  <div class="container-wide py-16 lg:py-20">
    <div class="grid gap-12 md:grid-cols-6">
      <div class="md:col-span-2">
        <a href="/" class="flex items-center gap-2 no-underline text-white">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-primary-500 text-white text-sm font-bold">Q</span>
          <span class="font-display text-lg font-semibold tracking-tight">Quvii</span>
        </a>
        <p class="mt-4 text-sm text-white/60 leading-relaxed max-w-sm">
          A US-headquartered connected-security technology brand. Field-level
          research on the cameras, sensors, and software shaping the modern home.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-white/90 mt-0">Work</h3>
        <ul class="mt-4 space-y-3 list-none p-0">
          <li><a href="/reviews/" class="text-sm text-white/60 hover:text-white no-underline transition-colors">Reviews</a></li>
          <li><a href="/learn/" class="text-sm text-white/60 hover:text-white no-underline transition-colors">Guides</a></li>
          <li><a href="/blog/" class="text-sm text-white/60 hover:text-white no-underline transition-colors">Insights</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-white/90 mt-0">Company</h3>
        <ul class="mt-4 space-y-3 list-none p-0">
          <li><a href="/about/" class="text-sm text-white/60 hover:text-white no-underline transition-colors">About</a></li>
          <li><a href="/editorial-policy/" class="text-sm text-white/60 hover:text-white no-underline transition-colors">Standards</a></li>
          <li><a href="mailto:hello@quvii.com" class="text-sm text-white/60 hover:text-white no-underline transition-colors">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-white/90 mt-0">Legal</h3>
        <ul class="mt-4 space-y-3 list-none p-0">
          <li><a href="/affiliate-disclosure/" class="text-sm text-white/60 hover:text-white no-underline transition-colors">Affiliate disclosure</a></li>
          <li><a href="/privacy/" class="text-sm text-white/60 hover:text-white no-underline transition-colors">Privacy</a></li>
          <li><a href="/terms/" class="text-sm text-white/60 hover:text-white no-underline transition-colors">Terms</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-white/90 mt-0">Stay in touch</h3>
        <p class="mt-4 text-sm text-white/60 leading-relaxed">
          One brief, every week. Field reports + analysis.
        </p>
        <a
          href="https://buttondown.com/quvii"
          target="_blank"
          rel="noopener"
          class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-white hover:text-primary-300 no-underline transition-colors"
        >
          Subscribe <span aria-hidden="true">›</span>
        </a>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-3 border-t border-white/10 pt-8 text-xs text-white/45 md:flex-row md:items-center">
      <p>© {new Date().getFullYear()} Quvii Inc. All rights reserved.</p>
      <p>
        Methodology — <a href="/editorial-policy/" class="underline decoration-white/30 hover:text-white hover:decoration-white transition-colors">Standards</a>
        · As an Amazon Associate, Quvii earns from qualifying purchases —
        <a href="/affiliate-disclosure/" class="underline decoration-white/30 hover:text-white hover:decoration-white transition-colors">Disclosure</a>.
      </p>
    </div>
  </div>
</footer>

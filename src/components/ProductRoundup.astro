---
// ProductRoundup — top-of-article wrapper that renders all frontmatter
// `products` as a stacked list of <ProductCard>s plus a quick-jump
// comparison table. Ported from ntecodex-site for quvii's light theme.
//
// Build-time kill-switch: AFFILIATE_EMBED_ENABLED=false suppresses all
// affiliate UI without touching content.

import ProductCard from "./ProductCard.astro";

interface Product {
  name: string;
  asin?: string;
  image?: string;
  price_usd?: number;
  rating?: number;
  review_count?: number;
  pros?: string[];
  cons?: string[];
  best_for?: string;
  affiliate_url?: string;
  verdict?: string;
}
interface Props { products: Product[] }

const { products } = Astro.props;
const enabledRaw = (import.meta.env.AFFILIATE_EMBED_ENABLED || "true").toString().toLowerCase();
const enabled = !["false", "0", "no", "off"].includes(enabledRaw);
const show = enabled && products && products.length > 0;
---

{show && (
  <section class="not-prose mb-10 space-y-6">
    {products.length > 1 && (
      <div class="overflow-x-auto rounded-xl border border-body-line bg-white shadow-card">
        <table class="w-full text-sm">
          <thead class="text-left text-xs uppercase tracking-wider text-body-faint">
            <tr>
              <th class="px-4 py-3 font-medium">#</th>
              <th class="px-4 py-3 font-medium">Product</th>
              <th class="px-4 py-3 font-medium">Best for</th>
              <th class="px-4 py-3 font-medium">Rating</th>
              <th class="px-4 py-3 font-medium">Price</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-body-line">
            {products.map((p, i) => (
              <tr>
                <td class="px-4 py-3 font-mono text-primary-600">{i + 1}</td>
                <td class="px-4 py-3 text-ink">
                  <a href={`#product-${i + 1}`} class="no-underline hover:text-primary-600">{p.name}</a>
                </td>
                <td class="px-4 py-3 text-body-muted">{p.best_for || "—"}</td>
                <td class="px-4 py-3 text-amber-600">
                  {p.rating != null ? `★ ${p.rating.toFixed(1)}` : "—"}
                </td>
                <td class="px-4 py-3 text-emerald-600">
                  {p.price_usd != null ? `$${p.price_usd.toFixed(0)}` : "—"}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <div class="space-y-5">
      {products.map((p, i) => (
        <div id={`product-${i + 1}`} class="scroll-mt-20">
          <ProductCard rank={i + 1} {...p} />
        </div>
      ))}
    </div>
  </section>
)}

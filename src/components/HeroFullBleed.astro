---
// Full-bleed hero — Apple/DJI flagship pattern.
// Dark backdrop (image OR gradient), giant centered display headline,
// single-line dek, optional pair of CTAs (text + chevron style).
//
// Accepts an optional `image` prop. If provided, image is used as
// backdrop with dark gradient overlay. Otherwise, dark gradient floor.

interface Props {
  eyebrow?: string;
  headline: string;
  dek?: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
  image?: string;
  align?: "left" | "center";
}

const {
  eyebrow,
  headline,
  dek,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
  image,
  align = "left",
} = Astro.props;

const alignClass = align === "center" ? "text-center mx-auto" : "text-left";
---

<section class={`relative isolate overflow-hidden ${image ? "bg-ink" : "bg-hero-floor"}`}>
  {image && (
    <>
      <img
        src={image}
        alt=""
        aria-hidden="true"
        loading="eager"
        fetchpriority="high"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
        style="filter: brightness(1.55) contrast(1.05) saturate(1.05);"
      />
      {/* Readability scrim.
          - Mobile/tablet (<lg): full-bleed horizontal AND vertical dark
            wash. Text spans the whole width so a left-only side fade
            won't help — drop a stronger bottom-up scrim plus a soft
            full overlay so the headline is always readable against
            whatever the image happens to show.
          - Desktop (lg+): Apple/DJI-style — dense on the left third
            where the headline sits, fully clear across the right 2/3
            so the brand image is unobstructed. */}
      <div class="absolute inset-0 bg-black/35 lg:hidden"></div>
      <div class="absolute inset-x-0 bottom-0 h-2/3 bg-gradient-to-t from-black/75 via-black/35 to-transparent lg:hidden"></div>
      <div class="absolute inset-0 hidden lg:block bg-gradient-to-r from-black/75 from-0% via-black/30 via-25% to-transparent to-55%"></div>
      <div class="absolute inset-x-0 bottom-0 h-16 hidden lg:block bg-gradient-to-t from-black/35 to-transparent"></div>
    </>
  )}

  <div class="relative container-wide pt-32 pb-20 sm:pt-40 sm:pb-28 lg:pt-48 lg:pb-36">
    <div class={`max-w-3xl ${alignClass}`}>
      {eyebrow && (
        <p class="text-xs font-medium uppercase tracking-[0.18em] text-white/60">
          {eyebrow}
        </p>
      )}
      <h1
        class="mt-5 font-display text-display-sm sm:text-display lg:text-display-lg text-white"
        style="text-shadow: 0 2px 24px rgba(0,0,0,0.55), 0 1px 2px rgba(0,0,0,0.35);"
      >
        {headline}
      </h1>
      {dek && (
        <p
          class="mt-6 max-w-2xl text-base sm:text-lg text-white/80 leading-relaxed"
          style="text-shadow: 0 1px 12px rgba(0,0,0,0.45);"
        >
          {dek}
        </p>
      )}

      {(primaryHref || secondaryHref) && (
        <div class="mt-10 flex flex-wrap items-center gap-4">
          {primaryHref && primaryLabel && (
            <a
              href={primaryHref}
              class="inline-flex items-center gap-1.5 rounded-full bg-white text-ink px-6 py-3 text-sm font-medium tracking-tight hover:bg-white/90 transition-colors"
            >
              {primaryLabel}
              <span aria-hidden="true">›</span>
            </a>
          )}
          {secondaryHref && secondaryLabel && (
            <a
              href={secondaryHref}
              class="inline-flex items-center gap-1.5 text-sm font-medium text-white/90 hover:text-white transition-colors"
            >
              {secondaryLabel}
              <span aria-hidden="true">›</span>
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</section>

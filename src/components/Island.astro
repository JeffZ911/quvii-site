---
// Floating island nav (Sunaofe "appear-after-hero" pattern). The main
// header sits at the very top; once the page scrolls past the hero, the
// main nav fades out and this compact pill slides in — brand + quick links
// + a persistent "Latest" CTA. One nav visible at a time, never both.
interface NavItem { href: string; label: string }
const nav: NavItem[] = [
  { href: "/reviews/", label: "Reviews" },
  { href: "/learn/",   label: "Guides"  },
  { href: "/blog/",    label: "Insights" },
];
---

<div
  id="qv-island"
  class="fixed top-3.5 left-1/2 z-50 hidden lg:flex items-center justify-between gap-6 w-[min(960px,calc(100%-1.5rem))] rounded-full pl-6 pr-2 h-14 pointer-events-none"
  aria-hidden="true"
>
  <a href="/" class="island-brand pointer-events-auto flex items-center no-underline" aria-label="Quvii — home">
    <img src="/brand/wordmark-ink.png" alt="Quvii" width="901" height="233" class="h-[17px] w-auto" />
  </a>
  <ul class="island-links pointer-events-auto flex items-center gap-7 list-none m-0 p-0">
    {nav.map((item) => (
      <li>
        <a href={item.href}
           class="text-sm font-medium text-body-muted hover:text-ink transition-colors duration-200 ease-apple no-underline">
          {item.label}
        </a>
      </li>
    ))}
  </ul>
  <a href="/blog/"
     class="island-cta pointer-events-auto inline-flex items-center gap-1.5 rounded-full bg-ink text-white pl-5 pr-4 py-2.5 text-sm font-semibold no-underline transition-transform duration-200 ease-apple hover:-translate-y-px">
    Latest <span aria-hidden="true">›</span>
  </a>
</div>

<style>
  /* Light-glass pill, matches the header's island language. */
  #qv-island {
    background: rgba(251,251,253,0.78);
    backdrop-filter: saturate(180%) blur(22px);
    -webkit-backdrop-filter: saturate(180%) blur(22px);
    box-shadow: inset 0 0 0 1px rgba(16,24,40,0.07),
                0 10px 34px rgba(16,24,40,0.10), 0 2px 8px rgba(16,24,40,0.05);
  }
  /* When the island is shown, fade the main header pill out. */
  #qv-nav.island-active .qv-pill {
    opacity: 0;
    transform: translateY(-12px);
    pointer-events: none;
  }
  #qv-nav .qv-pill {
    transition: opacity .4s cubic-bezier(.28,.11,.32,1),
                transform .4s cubic-bezier(.28,.11,.32,1),
                background-color .5s, box-shadow .5s, color .5s;
  }
</style>

<script is:inline>
  (function () {
    var island = document.getElementById("qv-island");
    var mainNav = document.getElementById("qv-nav");
    if (!island) return;
    // Threshold = ~62% of the first section / hero, falls back to 520px.
    var hero = document.querySelector("section");
    function threshold() { return hero ? hero.offsetHeight * 0.62 : 520; }
    var shown = false, ticking = false;
    function check() {
      ticking = false;
      var past = window.scrollY > threshold();
      if (past === shown) return;
      shown = past;
      island.classList.toggle("show", past);
      island.setAttribute("aria-hidden", String(!past));
      if (mainNav) mainNav.classList.toggle("island-active", past);
    }
    window.addEventListener("scroll", function () {
      if (!ticking) { ticking = true; requestAnimationFrame(check); }
    }, { passive: true });
    window.addEventListener("resize", check);
    check();
  })();
</script>

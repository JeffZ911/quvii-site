---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, any>;
  noindex?: boolean;
}

const {
  title,
  description = "Quvii Blog — AI product photography playbooks for Amazon, Shopify, Etsy, and TikTok Shop sellers.",
  ogImage,
  jsonLd,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site || "https://quvii.com").toString();
// AdSense publisher id is public (also lives in /ads.txt). Same
// publisher account as ntecodex — one account can serve multiple
// sites; blog.quvii.com still has to be added + reviewed in the
// AdSense console before ad units actually serve. The loader and
// ads.txt being present is what AdSense's crawler checks on review.
const adsensePub =
  import.meta.env.PUBLIC_ADSENSE_PUB_ID || "pub-5523706123080113";
const adsClient = adsensePub
  ? (adsensePub.startsWith("ca-") ? adsensePub : `ca-${adsensePub}`)
  : "";

// GA4 measurement id is public. Set via PUBLIC_GA_MEASUREMENT_ID env in
// CF Pages. Empty until you wire one in.
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || "";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Premium type (DESIGN.md §3): Clash Display (display) + Satoshi
         (body), from Fontshare. Inter is BANNED by the design system.
         Preconnect + a single stylesheet request; fonts are self-hosted
         by Fontshare's CDN with display=swap so text paints immediately. -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=clash-display@600,700&f[]=satoshi@400,500,700&display=swap"
    />

    <!-- Preconnect to 3rd-party origins that *will* be hit by the deferred
         AdSense + GA4 loaders below, so their DNS+TCP+TLS happens in
         parallel with the document parse instead of serially after. -->
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />

    {jsonLd && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}

    <!-- AdSense + GA4 are NOT critical for first paint. Boot them after
         the page is idle (or after first user interaction, whichever is
         first) so they don't compete with LCP for CPU + bandwidth on
         slow networks. Both still load as `async` once started, and the
         loader URLs/IDs are baked in at build time (public values).

         Trade-off: GA4 will miss the first ~1-3 seconds of pageviews
         that bounce instantly. Acceptable — those bounces aren't useful
         analytics anyway, and the mobile LCP win outweighs them. -->
    {(adsClient && adsensePub !== "pending") || gaId ? (
      <script is:inline set:html={`
        (function () {
          var booted = false;
          function boot() {
            if (booted) return;
            booted = true;
            ${adsClient && adsensePub !== "pending" ? `
            var ad = document.createElement('script');
            ad.async = true;
            ad.crossOrigin = 'anonymous';
            ad.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adsClient}';
            document.head.appendChild(ad);
            ` : ''}
            ${gaId ? `
            var ga = document.createElement('script');
            ga.async = true;
            ga.src = 'https://www.googletagmanager.com/gtag/js?id=${gaId}';
            document.head.appendChild(ga);
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', '${gaId}', { anonymize_ip: true });
            ` : ''}
          }
          // Boot when the browser is idle, OR after first user interaction,
          // whichever comes first. Cap at 4s so analytics still fire for
          // patient readers.
          if ('requestIdleCallback' in window) {
            requestIdleCallback(boot, { timeout: 4000 });
          } else {
            setTimeout(boot, 2500);
          }
          ['scroll','keydown','pointerdown','touchstart'].forEach(function (ev) {
            window.addEventListener(ev, boot, { once: true, passive: true });
          });
        })();
      `}></script>
    ) : null}
  </head>
  <body class="font-sans antialiased bg-surface text-body">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Cookie consent is handled by Google's CMP (Consent Management
         Platform) which is injected by the AdSense loader. We previously had
         a hand-rolled banner here; that's been removed so it doesn't shadow
         the CMP's GDPR-compliant Consent / Manage / Decline dialog. -->

    <!-- Scroll-reveal observer (DESIGN.md §8). One IntersectionObserver for
         every [data-reveal] on the page; reveals once, then unobserves.
         No scroll listener (GPU-safe). Skips entirely under reduced-motion. -->
    <script is:inline>
      (function () {
        var reduce = window.matchMedia &&
          window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var els = document.querySelectorAll('[data-reveal]');
        if (reduce || !('IntersectionObserver' in window)) {
          els.forEach(function (el) { el.classList.add('is-visible'); });
          return;
        }
        var io = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          });
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });
        els.forEach(function (el) { io.observe(el); });
      })();
    </script>

  </body>
</html>

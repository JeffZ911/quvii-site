---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import RelatedGuides from "../components/RelatedGuides.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ProductRoundup from "../components/ProductRoundup.astro";

// SourceList + CommentSection deliberately omitted (see prior notes):
// SourceList duplicated the writer-emitted ## Sources; CommentSection
// requires a CF Pages Functions backend not yet deployed on pixelmatch.

interface Crumb { href?: string; label: string }
interface Heading { depth: number; slug: string; text: string }
interface Product {
  name: string; asin?: string; image?: string;
  price_usd?: number; rating?: number; review_count?: number;
  pros?: string[]; cons?: string[]; best_for?: string;
  affiliate_url?: string; verdict?: string;
}
interface Props {
  title: string;
  description?: string;
  publishedAt?: string;
  qaScore?: number;
  wordCount?: number;
  articleType: string;
  platform?: string;
  heroImage?: string;
  sources?: any[];
  crumbs: Crumb[];
  slug?: string;
  /** 1-2 sentence answer-up-front callout. Frontmatter `quick_answer`. */
  quickAnswer?: string;
  /** Set true on frontmatter when article contains Amazon affiliate
   * links — renders FTC disclosure banner at top. */
  affiliate?: boolean;
  /** Markdown headings from `entry.render().headings`. When passed,
   * renders sticky right-side TOC on xl+ (≥1280px). */
  headings?: Heading[];
  /** Affiliate product list — when set + ProductRoundup mounts above body. */
  products?: Product[];
}

const {
  title, description, publishedAt, qaScore, wordCount,
  articleType, platform, heroImage, sources = [], crumbs, slug,
  quickAnswer, affiliate = false, headings = [], products,
} = Astro.props;

const dateStr = publishedAt
  ? new Date(publishedAt).toISOString().slice(0, 10)
  : null;

// Quality-gate noindex (mirrors ntecodex policy): qa_score < 6.0 (strong-
// tier band) gets noindex'd so we never let Google index pages we'd be
// embarrassed by. noindex,follow preserves link equity.
const NOINDEX_BELOW = 6.0;
const noindex = qaScore != null && qaScore < NOINDEX_BELOW;

const TYPE_LABEL: Record<string, string> = {
  tool_guide:    "Guide",
  vs_comparison: "Comparison",
  use_case:      "Case Study",
  policy_guide:  "Policy",
};
const PLATFORM_LABEL: Record<string, string> = {
  amazon_fba:  "Amazon",
  shopify:     "Shopify",
  etsy:        "Etsy",
  tiktok_shop: "TikTok Shop",
  multi:       "Multi-platform",
};
const PLATFORM_CLASS: Record<string, string> = {
  amazon_fba:  "bg-platform-amazon/10  text-platform-amazon",
  shopify:     "bg-platform-shopify/10 text-platform-shopify",
  etsy:        "bg-platform-etsy/10    text-platform-etsy",
  tiktok_shop: "bg-platform-tiktok/10  text-platform-tiktok",
  multi:       "bg-primary-50           text-primary-700",
};

const typeLabel = TYPE_LABEL[articleType] ?? articleType.replace("_", " ");
const platformLabel = PLATFORM_LABEL[platform || "multi"] || platform;
const platformClass = PLATFORM_CLASS[platform || "multi"] || PLATFORM_CLASS.multi;

// JSON-LD E-E-A-T fields (mirrors ntecodex): brand author + publishing-
// Principles + actionableFeedbackPolicy pointing to /editorial-policy/
// and /contact-feedback/. Google's documented trust signals.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  datePublished: publishedAt,
  dateModified: publishedAt,
  author: {
    "@type": "Organization",
    name: "Quvii Editorial",
    url: "https://quvii.com/about/",
  },
  publisher: {
    "@type": "Organization",
    name: "Quvii",
    url: "https://quvii.com/",
  },
  publishingPrinciples: "https://quvii.com/editorial-policy/",
  actionableFeedbackPolicy: "https://quvii.com/contact",
  description: description,
  ...(heroImage ? { image: heroImage } : {}),
};
---

<BaseLayout title={title} description={description} ogImage={heroImage} jsonLd={jsonLd} noindex={noindex}>
  <Breadcrumb crumbs={crumbs} />

  {/* 2-col grid on xl+: main article + sticky TOC sidebar. Collapses to
      single col on smaller screens (TOC hidden). */}
  <div class="xl:grid xl:grid-cols-[minmax(0,1fr)_14rem] xl:gap-10">
    <article class="prose-pm max-w-none min-w-0">
      {heroImage && (
        <img
          src={heroImage}
          alt=""
          width="1280" height="720"
          fetchpriority="high"
          class="mb-6 aspect-video w-full max-h-[400px] rounded-xl object-cover"
        />
      )}

      <header class="mb-6">
        <div class="flex flex-wrap items-center gap-2 text-xs">
          <span class="rounded bg-primary-50 px-2 py-0.5 font-medium text-primary-700">
            {typeLabel}
          </span>
          {platform && (
            <span class={`rounded px-2 py-0.5 font-medium ${platformClass}`}>
              {platformLabel}
            </span>
          )}
          {dateStr && <span class="text-body-faint">{dateStr}</span>}
          {wordCount != null && (
            <span class="text-body-faint">· {wordCount.toLocaleString()} words</span>
          )}
        </div>
        <h1 class="mt-3 text-balance text-ink">{title}</h1>
      </header>

      <div class="min-w-0">
        {affiliate && (
          <aside class="mb-6 rounded-lg border border-amber-300/40 bg-amber-50 px-4 py-3 text-sm text-amber-900">
            <strong class="text-amber-900">Affiliate disclosure:</strong>
            This article contains affiliate links. If you buy through them,
            we may earn a small commission at no cost to you. Recommendations
            are made independently — see our
            <a href="/affiliate-disclosure/" class="underline hover:text-amber-700">Affiliate Disclosure</a>
            and <a href="/editorial-policy/" class="underline hover:text-amber-700">Editorial Policy</a>.
          </aside>
        )}
        {quickAnswer && (
          <aside class="mb-6 rounded-xl border border-primary-300/40 bg-primary-50 px-5 py-4">
            <p class="m-0 text-xs font-semibold uppercase tracking-wider text-primary-700">
              Quick answer
            </p>
            <p class="mt-2 mb-0 text-base text-ink">{quickAnswer}</p>
          </aside>
        )}
        {products && products.length > 0 && (
          <ProductRoundup products={products} />
        )}
        <slot />
        {slug && <RelatedGuides currentSlug={slug} articleType={articleType} />}
      </div>
    </article>

    <TableOfContents headings={headings} />
  </div>
</BaseLayout>

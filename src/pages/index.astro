---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroFullBleed from "../components/HeroFullBleed.astro";
import ValueStrip from "../components/ValueStrip.astro";
import FeatureStory from "../components/FeatureStory.astro";
import ArticleTile from "../components/ArticleTile.astro";
import CategoryBanner from "../components/CategoryBanner.astro";
import NewsRibbon from "../components/NewsRibbon.astro";
import StandardsTeaser from "../components/StandardsTeaser.astro";
import PullQuote from "../components/PullQuote.astro";

// Quvii homepage — densified Apple/DJI-grade sectional rhythm.
//
// Fixed section structure (Jeff's directive — frame is standardized,
// content is dynamic):
//   1.  Hero (full-bleed, dark)
//   2.  ValueStrip — three lenses on connected security
//   3.  Featured story (magazine split)
//   4.  Wave 1 — six mixed-content tiles
//   5.  CategoryBanner #1 (Reviews focus)
//   6.  PullQuote — editorial voice
//   7.  Wave 2 — three secondary-wave tiles
//   8.  CategoryBanner #2 (Guides focus, dark tone)
//   9.  NewsRibbon — four compact industry signals
//   10. StandardsTeaser — credibility block
//   11. Newsletter
//   12. Footer
//
// All sections degrade gracefully when no content is available.

const blog = await getCollection("blog");
const learn = await getCollection("learn");
const reviews = await getCollection("reviews");

const NOINDEX_BELOW = 6.0;
const ok = <T extends { data: { qa_score?: number } }>(e: T) =>
  !(typeof e.data.qa_score === "number" && e.data.qa_score < NOINDEX_BELOW);

type Entry = (typeof blog)[number] & { _kind: "blog" | "learn" | "reviews" };

const all: Entry[] = [
  ...blog.map((e) => ({ ...e, _kind: "blog" as const })),
  ...learn.map((e) => ({ ...e, _kind: "learn" as const })),
  ...reviews.map((e) => ({ ...e, _kind: "reviews" as const })),
].filter(ok).sort(
  (a, b) => Date.parse(b.data.published_at || "") - Date.parse(a.data.published_at || "")
);

// Featured = highest qa_score among recently-published
const recencyWindow = all.slice(0, 18);
const featured = [...recencyWindow].sort(
  (a, b) => (b.data.qa_score || 0) - (a.data.qa_score || 0)
)[0];

const featuredId = featured?.id;
const rest = all.filter((e) => e.id !== featuredId);
const wave1 = rest.slice(0, 6);
const wave2 = rest.slice(6, 9);

// News stream = article_type=camera_news from /blog/
const NEWS_TYPES = new Set(["camera_news"]);
const news = blog
  .filter((e) => ok(e) && NEWS_TYPES.has(e.data.article_type))
  .sort((a, b) => Date.parse(b.data.published_at || "") - Date.parse(a.data.published_at || ""))
  .slice(0, 4)
  .map((e) => ({
    href: `/blog/${e.slug}/`,
    title: e.data.title,
    publishedAt: e.data.published_at,
  }));

// Visual banner imagery — prefer a recent review hero, then any
// recent hero image. Otherwise the banner renders with its dark
// gradient fallback (still on-brand).
const reviewSample = reviews.filter(ok).sort(
  (a, b) => Date.parse(b.data.published_at || "") - Date.parse(a.data.published_at || "")
)[0];
const learnSample = learn.filter(ok).sort(
  (a, b) => Date.parse(b.data.published_at || "") - Date.parse(a.data.published_at || "")
)[0];

// Brand assets — dedicated photoreal fixtures in /public/brand/ that
// do NOT depend on article content. Preferred over article hero_images
// for the homepage hero + CategoryBanner blocks so the visual identity
// stays stable across content cycles.
const BRAND_HERO          = "/brand/hero.png";
const BRAND_REVIEWS_IMG   = "/brand/reviews-banner.png";
const BRAND_GUIDES_IMG    = "/brand/guides-banner.png";

const reviewsBannerImage = BRAND_REVIEWS_IMG;
const guidesBannerImage  = BRAND_GUIDES_IMG;

const hrefFor = (e: Entry) => `/${e._kind}/${e.slug}/`;
const heroBackdrop = BRAND_HERO;

const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  url: "https://quvii.com/",
  name: "Quvii",
  inLanguage: "en-US",
  publisher: { "@type": "Organization", name: "Quvii", url: "https://quvii.com/" },
};
---

<BaseLayout
  title="Quvii — Connected security, refined."
  description="Industry signals, technical depth, and product intelligence across connected security. Independent research from a US-headquartered technology brand."
  jsonLd={siteJsonLd}
>
  <!-- 1. HERO -->
  <HeroFullBleed
    eyebrow="Quvii"
    headline="Connected security, refined."
    dek="Industry signals, technical depth, and product intelligence — the work that shapes how the modern home protects itself."
    primaryHref={featured ? hrefFor(featured as Entry) : "/blog/"}
    primaryLabel="Read the latest"
    secondaryHref="/about/"
    secondaryLabel="About Quvii"
    image={heroBackdrop}
  />

  <!-- 2. VALUE POSITIONING STRIP -->
  <ValueStrip />

  <!-- 3. FEATURED STORY -->
  {featured && (
    <section class="section bg-surface border-t border-body-line">
      <div class="container-page">
        <div data-reveal class="mb-12 lg:mb-16 max-w-2xl">
          <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary-600">Featured</p>
          <h2 class="mt-3 font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-ink leading-[1.1]">
            This week's deep dive.
          </h2>
        </div>
        <div data-reveal style="--reveal-delay:100ms">
        <FeatureStory
          href={hrefFor(featured as Entry)}
          title={featured.data.title}
          dek={featured.data.description}
          image={featured.data.hero_image}
          publishedAt={featured.data.published_at}
          wordCount={featured.data.word_count}
          eyebrow="Field report"
        />
        </div>
      </div>
    </section>
  )}

  <!-- 4. WAVE 1 — mixed content -->
  {wave1.length > 0 && (
    <section class="section bg-surface-alt">
      <div class="container-page">
        <div data-reveal class="flex items-end justify-between mb-10 lg:mb-14 flex-wrap gap-4">
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary-600">Currently tracking</p>
            <h2 class="mt-3 font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-ink leading-[1.1] max-w-2xl">
              What we're watching.
            </h2>
          </div>
          <a href="/blog/" class="group inline-flex items-center gap-1.5 text-sm font-medium text-primary-600 hover:text-primary-700 no-underline transition-colors duration-300 ease-settle">
            All work <span class="transition-transform duration-300 ease-settle group-hover:translate-x-0.5" aria-hidden="true">›</span>
          </a>
        </div>
        <div data-reveal style="--reveal-delay:120ms" class="grid gap-x-8 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
          {wave1.map((e) => (
            <ArticleTile
              href={hrefFor(e)}
              title={e.data.title}
              dek={e.data.description}
              image={e.data.hero_image}
              publishedAt={e.data.published_at}
              wordCount={e.data.word_count}
              aspect="4/3"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 5. CATEGORY BANNER — Reviews -->
  <CategoryBanner
    eyebrow="Reviews"
    headline="Measured, not marketed."
    body="In-depth technical analysis of connected security hardware. Real range, real subscription cost, real data-handling — the trade-offs the spec sheet won't show you."
    href="/reviews/"
    cta="Explore reviews"
    image={reviewsBannerImage}
    tone="light"
  />

  <!-- 6. EDITORIAL VOICE -->
  <PullQuote
    text="A camera is a system. A system is a set of decisions made by someone who isn't you. Quvii's work is to make those decisions visible — so the home owns its security, not the other way around."
  />

  <!-- 7. WAVE 2 — secondary -->
  {wave2.length > 0 && (
    <section class="section bg-surface">
      <div class="container-page">
        <div data-reveal class="mb-10 lg:mb-14 max-w-2xl">
          <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary-600">From the field</p>
          <h2 class="mt-3 font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-ink leading-[1.1]">
            Newer dispatches.
          </h2>
        </div>
        <div data-reveal style="--reveal-delay:120ms" class="grid gap-x-8 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
          {wave2.map((e) => (
            <ArticleTile
              href={hrefFor(e)}
              title={e.data.title}
              dek={e.data.description}
              image={e.data.hero_image}
              publishedAt={e.data.published_at}
              wordCount={e.data.word_count}
              aspect="4/3"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- 8. CATEGORY BANNER — Guides (dark tone) -->
  <CategoryBanner
    eyebrow="Guides"
    headline="Built on what works."
    body="Practical, technical guides to designing, installing, and operating connected home security. Hands-on knowledge from the field — not the spec sheet."
    href="/learn/"
    cta="Explore guides"
    image={guidesBannerImage}
    tone="dark"
    flip={true}
  />

  <!-- 9. NEWS RIBBON -->
  <NewsRibbon
    eyebrow="Signals"
    headline="From the wire."
    ctaHref="/news/"
    ctaLabel="All news"
    items={news}
  />

  <!-- 10. STANDARDS TEASER -->
  <StandardsTeaser />

  <!-- 11. NEWSLETTER -->
  <section class="section bg-surface-alt">
    <div data-reveal class="container-page max-w-3xl text-center mx-auto">
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary-600">Brief</p>
      <h2 class="mt-3 font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-ink leading-[1.1]">
        One brief, every week.
      </h2>
      <p class="mt-4 text-base text-body-muted max-w-xl mx-auto">
        Field reports, new analysis, and the signals that matter. Concise, unsponsored, unsubscribe anytime.
      </p>
      <form
        action="https://buttondown.com/api/emails/embed-subscribe/quvii"
        method="post"
        target="popupwindow"
        onsubmit="window.open('https://buttondown.com/quvii', 'popupwindow')"
        class="mt-8 flex flex-col gap-3 sm:flex-row max-w-md mx-auto"
      >
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          aria-label="Email address"
          class="flex-1 rounded-full border border-body-line bg-white px-5 py-3 text-sm text-ink placeholder-body-faint focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30"
        />
        <button
          type="submit"
          class="rounded-full bg-ink px-6 py-3 text-sm font-medium text-white hover:bg-body transition-all duration-300 ease-settle active:scale-[0.98] shadow-soft"
        >
          Subscribe
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

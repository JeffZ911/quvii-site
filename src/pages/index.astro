---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroFullBleed from "../components/HeroFullBleed.astro";
import FeatureStory from "../components/FeatureStory.astro";
import ArticleTile from "../components/ArticleTile.astro";
import PullQuote from "../components/PullQuote.astro";

// Quvii homepage — Apple / DJI-grade brand-tech outpost.
// Positioning is intentionally neutral: no "review site / blog / news"
// labels in copy. Page reads as a forward-looking technology brand
// publishing professional intelligence on connected security. Fixed
// section structure; article streams are dynamic (driven by content
// collections + qa_score + recency).

const blog = await getCollection("blog");
const learn = await getCollection("learn");
const reviews = await getCollection("reviews");

// Editorial floor — match sitemap policy
const NOINDEX_BELOW = 6.0;
const ok = <T extends { data: { qa_score?: number } }>(e: T) =>
  !(typeof e.data.qa_score === "number" && e.data.qa_score < NOINDEX_BELOW);

type Entry = (typeof blog)[number] & { _kind: "blog" | "learn" | "reviews" };

const all: Entry[] = [
  ...blog.map((e) => ({ ...e, _kind: "blog" as const })),
  ...learn.map((e) => ({ ...e, _kind: "learn" as const })),
  ...reviews.map((e) => ({ ...e, _kind: "reviews" as const })),
].filter(ok).sort(
  (a, b) => Date.parse(b.data.published_at || "") - Date.parse(a.data.published_at || "")
);

// Featured = highest qa_score among recently-published
const recencyWindow = all.slice(0, 18);
const featured = [...recencyWindow].sort(
  (a, b) => (b.data.qa_score || 0) - (a.data.qa_score || 0)
)[0];

const featuredId = featured?.id;
const rest = all.filter((e) => e.id !== featuredId);
const wave1 = rest.slice(0, 6);
const wave2 = rest.slice(6, 9);

const hrefFor = (e: Entry) => `/${e._kind}/${e.slug}/`;

const heroBackdrop = featured?.data.hero_image || undefined;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  url: "https://quvii.com/",
  name: "Quvii",
  description:
    "Quvii is a connected-security technology brand publishing field-level intelligence on the cameras, sensors, and software shaping the modern home.",
  inLanguage: "en-US",
  sameAs: [],
};

const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  url: "https://quvii.com/",
  name: "Quvii",
  inLanguage: "en-US",
  publisher: { "@type": "Organization", name: "Quvii", url: "https://quvii.com/" },
};
---

<BaseLayout
  title="Quvii — Connected security, refined."
  description="Quvii publishes field-tested intelligence on the cameras, sensors, and software shaping the modern home. Independent research, technical depth, professional standards."
  jsonLd={siteJsonLd}
>
  <!-- ====================== HERO ====================== -->
  <HeroFullBleed
    eyebrow="Quvii"
    headline="Connected security, refined."
    dek="Field-level intelligence on the cameras, sensors, and software shaping how the modern home protects itself."
    primaryHref={featured ? hrefFor(featured as Entry) : "/blog/"}
    primaryLabel="Read the latest"
    secondaryHref="/about/"
    secondaryLabel="About Quvii"
    image={heroBackdrop}
  />

  <!-- ====================== FEATURED STORY ====================== -->
  {featured && (
    <section class="section bg-surface">
      <div class="container-page">
        <FeatureStory
          href={hrefFor(featured as Entry)}
          title={featured.data.title}
          dek={featured.data.description}
          image={featured.data.hero_image}
          publishedAt={featured.data.published_at}
          wordCount={featured.data.word_count}
          eyebrow="Field report"
        />
      </div>
    </section>
  )}

  <!-- ====================== STREAM 1 — mixed content ====================== -->
  {wave1.length > 0 && (
    <section class="section-tight bg-surface-alt">
      <div class="container-page">
        <div class="flex items-end justify-between mb-10 lg:mb-14">
          <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-ink leading-[1.1] max-w-2xl">
            What we're watching
          </h2>
          <a href="/blog/" class="hidden sm:inline-flex items-center gap-1 text-sm font-medium text-primary-600 hover:text-primary-700 no-underline">
            See all <span aria-hidden="true">›</span>
          </a>
        </div>
        <div class="grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
          {wave1.map((e) => (
            <ArticleTile
              href={hrefFor(e)}
              title={e.data.title}
              dek={e.data.description}
              image={e.data.hero_image}
              publishedAt={e.data.published_at}
              wordCount={e.data.word_count}
              aspect="4/3"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ====================== EDITORIAL VOICE ====================== -->
  <PullQuote
    text="A camera is a system. A system is a set of decisions made by someone who isn't you. Quvii's work is to make those decisions visible — so the home owns its security, not the other way around."
  />

  <!-- ====================== STREAM 2 — secondary wave ====================== -->
  {wave2.length > 0 && (
    <section class="section bg-surface">
      <div class="container-page">
        <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-ink leading-[1.1] max-w-2xl mb-10 lg:mb-14">
          New from the field
        </h2>
        <div class="grid gap-x-8 gap-y-12 lg:grid-cols-3">
          {wave2.map((e) => (
            <ArticleTile
              href={hrefFor(e)}
              title={e.data.title}
              dek={e.data.description}
              image={e.data.hero_image}
              publishedAt={e.data.published_at}
              wordCount={e.data.word_count}
              aspect="4/3"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- ====================== STANDARDS / TRUST STRIP ====================== -->
  <section class="section-tight bg-ink text-white">
    <div class="container-page grid gap-10 lg:grid-cols-3">
      <div>
        <h3 class="font-display text-lg font-semibold tracking-tight text-white">Independent</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/65 max-w-sm">
          No paid placements. No vendor-controlled coverage. Every recommendation
          stands on its own technical merit.
        </p>
      </div>
      <div>
        <h3 class="font-display text-lg font-semibold tracking-tight text-white">Field-tested</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/65 max-w-sm">
          Decisions grounded in measurement: real range, real subscription cost,
          real data-handling — not spec sheets.
        </p>
      </div>
      <div>
        <h3 class="font-display text-lg font-semibold tracking-tight text-white">Forward-looking</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/65 max-w-sm">
          Connected security is a software problem dressed in hardware. We cover
          the systems behind the lens, not just the lens.
        </p>
      </div>
    </div>
  </section>

  <!-- ====================== NEWSLETTER ====================== -->
  <section class="section bg-surface-alt">
    <div class="container-page max-w-3xl text-center mx-auto">
      <h2 class="font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-ink leading-[1.1]">
        One brief, every week.
      </h2>
      <p class="mt-4 text-base text-body-muted max-w-xl mx-auto">
        Field reports, new analysis, and the signals that matter. Concise, unsponsored, unsubscribe anytime.
      </p>
      <form
        action="https://buttondown.com/api/emails/embed-subscribe/quvii"
        method="post"
        target="popupwindow"
        onsubmit="window.open('https://buttondown.com/quvii', 'popupwindow')"
        class="mt-8 flex flex-col gap-3 sm:flex-row max-w-md mx-auto"
      >
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          aria-label="Email address"
          class="flex-1 rounded-full border border-body-line bg-white px-5 py-3 text-sm text-ink placeholder-body-faint focus:border-primary-500 focus:outline-none focus:ring-2 focus:ring-primary-500/30"
        />
        <button
          type="submit"
          class="rounded-full bg-ink px-6 py-3 text-sm font-medium text-white hover:bg-body transition-colors"
        >
          Subscribe
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

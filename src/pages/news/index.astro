---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArticleTile from "../../components/ArticleTile.astro";

// News — independent industry-signal section. Articles continue to be
// published under /blog/{slug}/ for URL stability + SEO continuity;
// this page presents the article_type=camera_news subset as its own
// destination, with its own header tone.

const blog = await getCollection("blog");

const NOINDEX_BELOW = 6.0;
const ok = (e: typeof blog[number]) =>
  !(typeof e.data.qa_score === "number" && e.data.qa_score < NOINDEX_BELOW);

const NEWS_TYPES = new Set(["camera_news"]);

const news = blog
  .filter((e) => ok(e) && NEWS_TYPES.has(e.data.article_type))
  .sort((a, b) => Date.parse(b.data.published_at || "") - Date.parse(a.data.published_at || ""));

const featured = news[0];
const rest = news.slice(1);
---

<BaseLayout
  title="News — Quvii"
  description="The launches, policy shifts, and platform decisions reshaping connected security — separated from the marketing cycle that surrounds them."
>
  <div class="container-page py-14 lg:py-20">
    <div class="max-w-3xl">
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary-600">News</p>
      <h1 class="mt-4 font-display text-display-sm sm:text-display tracking-display text-ink leading-[1.05]">
        Signals from the field.
      </h1>
      <p class="mt-6 text-lg text-body-muted leading-relaxed max-w-2xl">
        The launches, policy shifts, and platform decisions reshaping connected
        security — separated from the marketing cycle that surrounds them.
      </p>
    </div>

    {featured && (
      <div class="mt-14 lg:mt-20">
        <a href={`/blog/${featured.slug}/`} class="group grid items-center gap-10 lg:gap-16 lg:grid-cols-[1.1fr_1fr]">
          <div class="relative overflow-hidden rounded-2xl bg-surface-alt aspect-[4/3]">
            {featured.data.hero_image ? (
              <img src={featured.data.hero_image} alt="" loading="lazy" decoding="async"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]" />
            ) : (
              <div class="h-full w-full bg-gradient-to-br from-ink-soft to-ink-deep"></div>
            )}
          </div>
          <div>
            <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary-600">Latest signal</p>
            <h2 class="mt-3 font-display text-2xl sm:text-3xl lg:text-4xl font-semibold tracking-display text-ink leading-[1.1]">
              {featured.data.title}
            </h2>
            {featured.data.description && (
              <p class="mt-4 text-base text-body-muted leading-relaxed max-w-xl">{featured.data.description}</p>
            )}
            <span class="mt-6 inline-flex items-center gap-1 text-sm font-medium text-primary-600 group-hover:text-primary-700">
              Read <span aria-hidden="true">›</span>
            </span>
          </div>
        </a>
      </div>
    )}

    {rest.length > 0 && (
      <div class="mt-20 lg:mt-28 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
        {rest.map((e) => (
          <ArticleTile
            href={`/blog/${e.slug}/`}
            title={e.data.title}
            dek={e.data.description}
            image={e.data.hero_image}
            publishedAt={e.data.published_at}
            wordCount={e.data.word_count}
            aspect="4/3"
          />
        ))}
      </div>
    )}

    {news.length === 0 && (
      <div class="mt-14 text-body-muted">
        No signals published yet — fresh dispatches arrive multiple times a week.
      </div>
    )}
  </div>
</BaseLayout>

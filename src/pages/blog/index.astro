---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import CollectionIndex from "../../components/CollectionIndex.astro";

const entries = await getCollection("blog");
---

<BaseLayout
  title="Insights — Quvii"
  description="Field-level analysis on the cameras, sensors, and software shaping connected security. Industry intelligence, technical research, and signal worth tracking."
>
  <CollectionIndex
    eyebrow="Insights"
    headline="Field-level analysis."
    dek="Industry intelligence, technical research, and the signals worth tracking in connected security."
    kind="blog"
    entries={entries}
  />
</BaseLayout>

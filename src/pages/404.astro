---
// P0 fix (inherited from ntecodex 2026-05-13): explicit 404 page so
// Cloudflare Pages stops serving the homepage HTML for missing routes.
// Astro builds this to dist/404.html — CF Pages serves it with a real
// 404 status for any path that isn't a built static asset.

import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout
  title="Not found — Quvii"
  description="The page you were looking for doesn't exist."
  noindex={true}
>
  <section class="container-page py-24 lg:py-32 text-center">
    <p class="text-xs font-medium uppercase tracking-[0.18em] text-primary-600">404</p>
    <h1 class="mt-4 font-display text-display-sm sm:text-display tracking-display text-ink leading-[1.05]">
      This page doesn't exist.
    </h1>
    <p class="mt-6 text-base text-body-muted max-w-lg mx-auto leading-relaxed">
      The URL you opened doesn't match anything on Quvii. The page may have been renamed, or hasn't been published yet.
    </p>
    <div class="mt-10 flex flex-wrap justify-center gap-4">
      <a href="/" class="btn-primary">Home <span aria-hidden="true">›</span></a>
      <a href="/blog/" class="btn-secondary">All work <span aria-hidden="true">›</span></a>
    </div>
  </section>
</BaseLayout>
